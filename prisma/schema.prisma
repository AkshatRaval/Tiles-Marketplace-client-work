generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Dealer {
  id        String   @id @default(uuid())
  name      String
  shopName  String
  phone     String
  city      String
  state     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tiles     Tile[]
}

model Tile {
  id           String          @id @default(uuid())
  name         String
  sku          String          @unique
  category     TileCategory
  material     TileMaterial
  finish       TileFinish
  color        TileColor
  size         String
  application  TileApplication
  mount        TileMount
  pricePerSqft Float
  pricePerBox  Float
  stock        Int
  description  String?
  pdfUrl       String?
  isPublished  Boolean         @default(true)
  dealerId     String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  bookingTiles BookingTile[]
  cartItems    CartItem[]
  reviews      Review[]
  dealer       Dealer          @relation(fields: [dealerId], references: [id])
  images       TileImage[]
  wishlist     Wishlist[]

  @@index([category])
  @@index([isPublished])
}

model TileImage {
  id        String   @id @default(uuid())
  imageUrl  String
  tileId    String
  createdAt DateTime @default(now())
  tile      Tile     @relation(fields: [tileId], references: [id], onDelete: Cascade)
}

/// //////////////////////////////////////////////
/// //////////////////////////////////////////////
model EndUser {
  id          String     @id @default(uuid())
  name        String
  email       String     @unique
  phone       String?
  city        String?
  address     String?
  state       String?
  pincode     String?
  duty        String?
  lookingFor  String[]   @default([])
  referral    String?
  isOnboarded Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookings    Booking[]
  cart        Cart?
  wishlist    Wishlist[]

  @@index([email])
  @@index([city])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      EndUser    @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id          String   @id @default(uuid())
  cartId      String
  tileId      String
  quantityBox Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  tile        Tile     @relation(fields: [tileId], references: [id])

  @@unique([cartId, tileId])
}

model Booking {
  id           String        @id @default(uuid())
  customerName String
  phone        String
  email        String?
  city         String
  address      String?
  quantityBox  Int
  meetingDate  DateTime?
  adminNotes   String?
  status       BookingStatus @default(NEW)
  userId       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         EndUser?      @relation(fields: [userId], references: [id])
  tiles        BookingTile[]

  @@index([status])
}

model BookingTile {
  id        String  @id @default(uuid())
  bookingId String
  tileId    String
  quantity  Int     @default(1)
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tile      Tile    @relation(fields: [tileId], references: [id])

  @@index([bookingId])
  @@index([tileId])
}

model Review {
  id        String   @id @default(uuid())
  tileId    String
  name      String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  tile      Tile     @relation(fields: [tileId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  tileId    String
  createdAt DateTime @default(now())
  tile      Tile     @relation(fields: [tileId], references: [id], onDelete: Cascade)
  user      EndUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tileId])
  @@index([userId])
  @@index([tileId])
}

