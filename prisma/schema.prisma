generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////////////////////////////////
// ENUMS
/////////////////////////////////////////////////

enum TileCategory {
  FLOOR
  WALL
  BATHROOM
  KITCHEN
  OUTDOOR
}

enum TileFinish {
  GLOSSY
  MATTE
  SATIN
}

enum BookingStatus {
  NEW
  CONTACTED
  CONFIRMED
  CANCELLED
}

/////////////////////////////////////////////////
// ADMIN (SYSTEM OPERATOR)
/////////////////////////////////////////////////

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

/////////////////////////////////////////////////
// DEALER (INTERNAL, NOT SHOWN TO USERS)
/////////////////////////////////////////////////

model Dealer {
  id        String   @id @default(uuid())
  name      String
  shopName  String
  phone     String
  city      String
  state     String
  isActive  Boolean  @default(true)

  tiles     Tile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/////////////////////////////////////////////////
// TILE (PUBLIC PRODUCT)
/////////////////////////////////////////////////

model Tile {
  id           String        @id @default(uuid())
  name         String
  sku          String        @unique

  category     TileCategory
  material     String
  finish       TileFinish
  size         String

  pricePerSqft Float
  pricePerBox  Float
  stock        Int

  description  String?
  pdfUrl       String?
  isPublished  Boolean       @default(true)

  dealerId     String
  dealer       Dealer        @relation(fields: [dealerId], references: [id])
  images       TileImage[]
  cartItems    CartItem[]
  wishlist     Wishlist[]  // Add this
  bookings     Booking[]
  reviews      Review[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([category])
  @@index([isPublished])
}

/////////////////////////////////////////////////
// TILE IMAGES
/////////////////////////////////////////////////

model TileImage {
  id        String   @id @default(uuid())
  imageUrl  String

  tileId    String
  tile      Tile     @relation(fields: [tileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/////////////////////////////////////////////////
// END USER (CUSTOMER)
/////////////////////////////////////////////////
model EndUser {
  id        String   @id @default(uuid())
  
  // Existing fields (keep as is)
  name      String
  email     String   @unique
  phone     String?
  city      String?

  // NEW fields - all optional with ? or @default
  address     String?
  state       String?
  pincode     String?
  duty        String?
  lookingFor  String[]  @default([])
  referral    String?
  isOnboarded Boolean   @default(false)
  
  // Relations
  cart      Cart?
  bookings  Booking[]
  wishlist  Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([email])
  @@index([city])
}

/////////////////////////////////////////////////
// CART (ONE ACTIVE CART PER USER)
/////////////////////////////////////////////////

model Cart {
  id        String     @id @default(uuid())

  userId    String     @unique
  user      EndUser   @relation(fields: [userId], references: [id])

  items     CartItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

/////////////////////////////////////////////////
// CART ITEM (MULTIPLE TILES IN CART)
/////////////////////////////////////////////////

model CartItem {
  id          String   @id @default(uuid())

  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  tileId      String
  tile        Tile     @relation(fields: [tileId], references: [id])

  quantityBox Int

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cartId, tileId])
}

/////////////////////////////////////////////////
// BOOKING (FINAL ENQUIRY / DROP-SHIP REQUEST)
/////////////////////////////////////////////////

model Booking {
  id            String        @id @default(uuid())

  customerName  String
  phone         String
  email         String?
  city          String
  address       String?

  quantityBox   Int
  status        BookingStatus @default(NEW)

  tileId        String
  tile          Tile          @relation(fields: [tileId], references: [id])

  userId        String?
  user          EndUser?      @relation(fields: [userId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([tileId])
}


model Review {
  id        String   @id @default(uuid())

  tileId    String
  tile      Tile     @relation(fields: [tileId], references: [id], onDelete: Cascade)

  name      String
  rating    Int      // 1–5
  comment   String?

  createdAt DateTime @default(now())
}


model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      EndUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tileId    String
  tile      Tile     @relation(fields: [tileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, tileId])
  @@index([userId])
  @@index([tileId])
}